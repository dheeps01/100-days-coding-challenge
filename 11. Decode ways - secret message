import java.util.*;
public class Solution{
    public static int decode(String s, int i){
        //reached end -> one valid ans
        if(i==s.length()){
            return 1;
        }
        //starts with 0 -> invalid
        if(s.charAt(i)=='0'){
            return 0;
        }
        
        //single digit
        int ways=decode(s,i+1);
        
        //if possible take 2 digits
        if(i+1 < s.length()){
            int num=Integer.parseInt(s.substring(i,i+2));
            
            if(num>=10 && num<=26){
                ways+=decode(s,i+2);
            }
        }
        return ways;
    }
    
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        String s=sc.nextLine();
        System.out.println(decode(s,0));
    }
}
