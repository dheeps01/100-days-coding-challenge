import java.util.*;
public class Solution{
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        
        for(int i=1;i<=n;i++){
            System.out.print(i+" ");
            int num=i;
            for(int j=n;j>i;j--){
                num=num+j;
                System.out.print(num+" ");
            }
            System.out.println();
            
        }
    }
}
