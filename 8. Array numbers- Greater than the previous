import java.util.*;
public class Solution{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int arr[] = new int[n];
        
        for(int i=0; i<n; i++){
            arr[i]=sc.nextInt();
        }
        
        System.out.print(arr[0]+" ");
        int temp=arr[0];
        for(int i=1;i<n;i++){
            if(arr[i]>temp){
                System.out.print(arr[i]+" ");
                temp=arr[i];
            }
        }
    }
}
