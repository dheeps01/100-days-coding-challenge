import java.util.*;
public class Solution{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        
        int n=sc.nextInt();
        String nums="";
        
        for(int i=1;i<=n;i++){
            nums=nums+i;
        }
        
        System.out.println(nums.length());
    }
}
