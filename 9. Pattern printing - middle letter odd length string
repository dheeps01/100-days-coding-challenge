import java.util.*;
public class Solution{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        
        String str = sc.nextLine();
        
        int n = str.length();
        int start=n/2;
        
        for(int i=0;i<n;i++){
            //print stars
            for(int j=0;j<n-i-1;j++){
                System.out.print("*");
            }
            
            //print letters
            for(int j=0;j<=i;j++){
                int index=(start+j)%n;
                System.out.print(str.charAt(index));
            }
            System.out.println();
        }
    }
}
