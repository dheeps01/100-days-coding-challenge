import java.util.*;
public class Solution{
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        int arr[]=new int[6];
        for(int i=0;i<6;i++){
            arr[i]=sc.nextInt();
        }
        
        for(int i=0;i<arr.length;i++){
            int num=arr[i];
            boolean isTrue=true;
            for(int j=i+1;j<arr.length;j++){
                if(num<arr[j]){
                    isTrue=false;
                }
            }
            if(isTrue){
                System.out.print(num+" ");
            }
        }
    }
}
